<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:orientation="vertical"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="16dp"
            android:background="#F5F5F5">

            <!-- 标题栏 -->
            <TextView
                android:id="@+id/tvTitleLearning"
                android:textSize="22sp"
                android:textStyle="bold"
                android:textColor="#1E90FF"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="📖 今天学的单词"
                android:gravity="center"/>

            <!-- 当前单词展示区 -->
            <LinearLayout
                android:orientation="vertical"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:background="#FFFFFF"
                android:padding="16dp"
                android:elevation="4dp">

                <TextView
                    android:id="@+id/tvWordText"
                    android:textSize="36sp"
                    android:textStyle="bold"
                    android:textColor="#000000"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="apple"
                    android:gravity="center"/>

                <TextView
                    android:id="@+id/tvPronunciation"
                    android:textSize="18sp"
                    android:textColor="#666666"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="/ˈæpl/"
                    android:gravity="center"/>

                <!-- 单词发音按钮 -->
                <Button
                    android:id="@+id/btnSpeakWord"
                    android:layout_width="wrap_content"
                    android:layout_height="40dp"
                    android:layout_gravity="center"
                    android:layout_marginTop="6dp"
                    android:text="🔊 读单词"
                    android:textSize="14sp"
                    android:textColor="#FFFFFF"
                    android:backgroundTint="#2196F3"/>

                <TextView
                    android:id="@+id/tvPartOfSpeech"
                    android:textSize="16sp"
                    android:textColor="#333333"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="词性：名词 (n.)"
                    android:gravity="center"/>

                <!-- 释义（答题前隐藏，答后显示） -->
                <TextView
                    android:id="@+id/tvDefinition"
                    android:textSize="20sp"
                    android:textColor="#999999"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="❓ 答对后显示释义"
                    android:gravity="center"/>

                <!-- 例句英文 -->
                <TextView
                    android:id="@+id/tvExampleEn"
                    android:textSize="15sp"
                    android:textColor="#333333"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="I eat an apple every day."
                    android:gravity="center"/>

                <!-- 例句中文翻译（答题前隐藏） -->
                <TextView
                    android:id="@+id/tvExampleCn"
                    android:textSize="15sp"
                    android:textColor="#666666"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text=""
                    android:visibility="gone"
                    android:gravity="center"/>
            </LinearLayout>

            <!-- 答题提示 -->
            <TextView
                android:id="@+id/tvQuizHint"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="#333333"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="🤔 这个单词的中文意思是什么？"
                android:gravity="center"/>

            <!-- 选项按钮区 -->
            <LinearLayout
                android:orientation="vertical"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp">

                <Button
                    android:id="@+id/btnOptionA"
                    android:textSize="16sp"
                    android:textColor="#FFFFFF"
                    android:backgroundTint="#4CAF50"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:text="A. 苹果"
                    android:layout_marginBottom="8dp"/>

                <Button
                    android:id="@+id/btnOptionB"
                    android:textSize="16sp"
                    android:textColor="#FFFFFF"
                    android:backgroundTint="#FF9800"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:text="B. 香蕉"
                    android:layout_marginBottom="8dp"/>

                <Button
                    android:id="@+id/btnOptionC"
                    android:textSize="16sp"
                    android:textColor="#FFFFFF"
                    android:backgroundTint="#FF5722"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:text="C. 汽车"/>
            </LinearLayout>

            <!-- 进度和下一步按钮 -->
            <LinearLayout
                android:id="@+id/progressLayout2"
                android:orientation="horizontal"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="16dp"
                android:gravity="center">

                <TextView
                    android:id="@+id/tvProgressText"
                    android:textSize="16sp"
                    android:textColor="#666666"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="1/5 | 20% 完成"/>

                <Button
                    android:id="@+id/btnNextWord"
                    android:textSize="16sp"
                    android:textColor="#FFFFFF"
                    android:backgroundTint="#2196F3"
                    android:layout_width="wrap_content"
                    android:layout_height="48dp"
                    android:layout_marginStart="24dp"
                    android:text="下一个 →"/>
            </LinearLayout>
        </LinearLayout>
    </ScrollView>
</FrameLayout>
