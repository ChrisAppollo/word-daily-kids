<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:id="@+id/progressLayout"
        android:orientation="vertical"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:padding="24dp"
        android:background="#F5F5F5">

        <!-- 标题栏 -->
        <TextView
            android:id="@+id/tvTitleLearning"
            android:textSize="28sp"
            android:textStyle="bold"
            android:textColor="#1E90FF"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="📖 今天学的单词"
            android:gravity="center"/>

        <!-- 当前单词展示区 -->
        <LinearLayout
            android:orientation="vertical"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            android:background="#FFFFFF"
            android:padding="24dp"
            android:elevation="8dp">

            <TextView
                android:id="@+id/tvWordText"
                android:textSize="48sp"
                android:textStyle="bold"
                android:textColor="#000000"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="apple"
                android:gravity="center"/>

            <TextView
                android:id="@+id/tvPronunciation"
                android:textSize="24sp"
                android:textColor="#666666"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="/\\u0259pl/  [音频播放]"
                android:gravity="center"/>

            <TextView
                android:id="@+id/tvPartOfSpeech"
                android:textSize="20sp"
                android:textColor="#333333"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="词性：名词 (n.)"
                android:gravity="center"/>

            <TextView
                android:id="@+id/tvDefinition"
                android:textSize="24sp"
                android:textColor="#FF0000"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="苹果"
                android:gravity="center"/>

            <TextView
                android:id="@+id/tvExampleEn"
                android:textSize="20sp"
                android:textColor="#333333"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="I eat an apple every day."
                android:gravity="center"/>

            <TextView
                android:id="@+id/tvExampleCn"
                android:textSize="20sp"
                android:textColor="#333333"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="我每天吃一个苹果。"
                android:gravity="center"/>
        </LinearLayout>

        <!-- 选项按钮区 -->
        <LinearLayout
            android:orientation="horizontal"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            android:gravity="center">

            <Button
                android:id="@+id/btnOptionA"
                android:textSize="20sp"
                android:textColor="#FFFFFF"
                android:backgroundTint="#4CAF50"
                android:layout_width="150dp"
                android:layout_height="60dp"
                android:text="正确 ✅"
                android:layout_marginEnd="16dp"/>

            <Button
                android:id="@+id/btnOptionB"
                android:textSize="20sp"
                android:textColor="#FFFFFF"
                android:backgroundTint="#FF9800"
                android:layout_width="150dp"
                android:layout_height="60dp"
                android:text="错误 ❌"
                android:layout_marginEnd="16dp"/>

            <Button
                android:id="@+id/btnOptionC"
                android:textSize="20sp"
                android:textColor="#FFFFFF"
                android:backgroundTint="#FF5722"
                android:layout_width="150dp"
                android:layout_height="60dp"
                android:text="不确定 ⚠️"/>
        </LinearLayout>

        <!-- 进度和下一步按钮 -->
        <LinearLayout
            android:id="@+id/progressLayout2"
            android:orientation="horizontal"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            android:gravity="center">

            <TextView
                android:id="@+id/tvProgressText"
                android:textSize="18sp"
                android:textColor="#666666"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="1/5 | 20% 完成"/>

            <Button
                android:id="@+id/btnNextWord"
                android:textSize="20sp"
                android:textColor="#FFFFFF"
                android:backgroundTint="#2196F3"
                android:layout_width="wrap_content"
                android:layout_height="56dp"
                android:layout_marginStart="48dp"
                android:text="下一个单词 →"/>
        </LinearLayout>
    </LinearLayout>
</FrameLayout>