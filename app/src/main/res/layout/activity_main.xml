<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <!-- Main home screen content -->
    <LinearLayout
        android:id="@+id/homeLayout"
        android:orientation="vertical"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:padding="24dp">

        <TextView
            android:id="@+id/tvTitle"
            android:textStyle="bold"
            android:textSize="36sp"
            android:textColor="@color/primary"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/app_name"
            android:gravity="center"
            android:layout_marginTop="48dp" />

        <LinearLayout
            android:orientation="horizontal"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            android:gravity="center">

            <TextView
                android:id="@+id/tvStreakCount"
                android:textSize="20sp"
                android:textColor="@color/textDark"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/streak_label"
                android:gravity="center" />
        </LinearLayout>

        <Button
            android:id="@+id/btnStartLearning"
            android:textSize="22sp"
            android:textColor="@color/buttonTextOnAccent"
            android:backgroundTint="@color/accent"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="48dp"
            android:text="@string/start_learning"
            android:textAlignment="center"
            android:padding="16dp" />

        <TextView
            android:id="@+id/tvDailyTip"
            android:textSize="16sp"
            android:textColor="@color/textLight"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="@string/tip_of_day"
            android:gravity="center" />
    </LinearLayout>

    <!-- Fragment container for learning screen (full screen overlay) -->
    <FrameLayout
        android:id="@+id/fragmentContainer"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone" />

</FrameLayout>
